generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean
  image         String?
  createdAt     DateTime
  updatedAt     DateTime

  sessions      Session[]
  accounts      Account[]
  
  // New Relations (M1.1)
  userProfile   UserProfile?
  credits       Int       @default(100)
  subscription  Subscription?
  usageRecords  UsageRecord[]
  generations   Generation[]
  competitors   Competitor[]
  affiliate     Affiliate?    @relation("UserAffiliate")
  referredBy    Referral?     @relation("ReferredUser")
  abuseLogs     AbuseLog[]
  youtubeConnection YoutubeConnection?
  chatSessions  ChatSession[]
  affiliateApplication AffiliateApplication?
  creditLogs    CreditLog[]

  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  token     String   @unique
  createdAt DateTime
  updatedAt DateTime

  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?

  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  serialized String?  @default("false")
  createdAt  DateTime? 
  updatedAt  DateTime?

  @@map("verification")
}

// --- New Models (M1.1) ---

model UserProfile {
  id                 String   @id @default(cuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName        String?
  avatar             String?
  niche              String?
  youtubeChannelId   String?
  onboardingComplete Boolean  @default(false)
  country            String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("user_profile")
}

model Subscription {
  id                    String             @id @default(cuid())
  userId                String             @unique
  user                  User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan                  Plan               @default(FREE)
  billingCycle          BillingCycle       @default(MONTHLY)
  status                SubscriptionStatus @default(TRIALING)
  gateway               Gateway?
  gatewaySubscriptionId String?
  trialEndsAt           DateTime?
  currentPeriodEnd      DateTime?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  @@map("subscription")
}

model UsageRecord {
  id      String   @id @default(cuid())
  userId  String
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  feature Feature
  date    DateTime @db.Date
  count   Int      @default(0)

  @@unique([userId, feature, date])
  @@map("usage_record")
}

model Generation {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  feature    Feature
  input      Json
  output     Json
  model      String?
  tokensUsed Int?
  isFavorite Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@map("generation")
}

model Competitor {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  channelId     String
  channelName   String
  channelHandle String?
  thumbnailUrl  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, channelId])
  @@map("competitor")
}

model Coupon {
  id              String   @id @default(cuid())
  code            String   @unique
  discountPercent Int
  expiresAt       DateTime?
  maxUses         Int?
  usedCount       Int      @default(0)
  perUserLimit    Int?
  country         String?
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("coupon")
}

model Affiliate {
  id                   String             @id @default(cuid())
  userId               String             @unique
  user                 User               @relation("UserAffiliate", fields: [userId], references: [id], onDelete: Cascade)
  referralCode         String             @unique
  commissionRate       Decimal            @default(0.1) @db.Decimal(10, 2)
  enabled              Boolean            @default(true)
  clicks               Int                @default(0)
  adminNotes           String?            @db.Text
  affiliateCredits     Int                @default(0)
  withdrawnCredits     Int                @default(0)
  totalEarningsDecimal Decimal            @default(0.00) @db.Decimal(10, 2)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  referrals            Referral[]
  withdrawalRequests   WithdrawalRequest[]

  @@map("affiliate")
}

model Referral {
  id               String         @id @default(cuid())
  affiliateId      String
  affiliate        Affiliate      @relation(fields: [affiliateId], references: [id])
  referredUserId   String         @unique
  referredUser     User           @relation("ReferredUser", fields: [referredUserId], references: [id], onDelete: Cascade)
  convertedAt      DateTime?
  commissionAmount Decimal?       @db.Decimal(10, 2)
  status           ReferralStatus @default(PENDING)
  ipAddress        String?
  isGoogleSignup   Boolean        @default(false)
  creditedAt       DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@map("referral")
}

model AffiliateApplication {
  id          String            @id @default(cuid())
  userId      String            @unique
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  status      ApplicationStatus @default(PENDING)
  channelLink String?
  niche       String?
  socialLinks Json?
  motivation  String?           @db.Text
  adminNotes  String?           @db.Text
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@map("affiliate_application")
}

model WithdrawalRequest {
  id             String           @id @default(cuid())
  affiliateId    String
  affiliate      Affiliate        @relation(fields: [affiliateId], references: [id])
  creditsAmount  Int
  monetaryAmount Decimal          @db.Decimal(10, 2)
  currency       String           @default("INR")
  method         WithdrawalMethod
  paymentDetails Json
  status         WithdrawalStatus @default(PENDING)
  adminNotes     String?          @db.Text
  processedAt    DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@map("withdrawal_request")
}

model AbuseLog {
  id        String     @id @default(cuid())
  userId    String?
  user      User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  event     AbuseEvent
  metadata  Json?
  createdAt DateTime   @default(now())

  @@map("abuse_log")
}

model YoutubeConnection {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  channelId       String
  channelTitle    String
  channelHandle   String?
  thumbnailUrl    String?
  subscriberCount BigInt   @default(0)
  accessToken     String   @db.Text
  refreshToken    String   @db.Text
  tokenExpiresAt  DateTime
  connectedAt     DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("youtube_connection")
}

model ChatSession {
  id        String        @id @default(cuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String        @default("New Coaching Session")
  summary   String?       @db.Text
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]

  @@map("chat_session")
}

model ChatMessage {
  id              String       @id @default(cuid())
  sessionId       String
  session         ChatSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role            String       // "user" or "assistant" or "system"
  content         String       @db.Text
  isDeepThinking  Boolean      @default(false)
  deepThinkingLog String?      @db.Text
  createdAt       DateTime     @default(now())

  @@map("chat_message")
}

// --- Enums ---

enum Plan {
  FREE
  LIMITED_PRO
  UNLIMITED_PRO
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  EXPIRED
  TRIALING
  PAST_DUE
}

enum Gateway {
  STRIPE
  RAZORPAY
}

enum Feature {
  VIDEO_SEO
  SCRIPT_WRITER
  SCRIPT_SHORTENER
  HOOK_DETECTOR
  CONTENT_SAFETY
  TOPIC_GENERATOR
  COMPETITORS
  CONSISTENCY_CHECKER
  NICHE_FINDER
  THUMBNAIL_CONCEPT
  GROWTH_DASHBOARD
}

enum AbuseEvent {
  RATE_LIMIT
  BURST
  SUSPICIOUS_IP
}

enum ReferralStatus {
  PENDING
  CREDITED
  PAID
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum WithdrawalMethod {
  UPI
  BANK
  PAYPAL
}

model CreditLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    Int      // Positive for added, negative for removed
  reason    String
  adminId   String
  createdAt DateTime @default(now())

  @@map("credit_log")
}
